# ============================================================================
# Omniflow — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit a real .env file to source control.
# ============================================================================


# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------

# Runtime environment: development | test | production
NODE_ENV=development

# Port the API server listens on
PORT=3001

# Verbosity: debug | info | warn | error
LOG_LEVEL=info

# Public-facing URLs (no trailing slash)
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Application display name (used in emails etc.)
APP_NAME="Omniflow"

# 32-byte (64 hex chars) encryption key — generate with:
#   node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
ENCRYPTION_KEY=


# ----------------------------------------------------------------------------
# Database — PostgreSQL
# ----------------------------------------------------------------------------

# Full connection string including database name, user, and password.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://omniflow:omniflow_password@localhost:5432/omniflow_dev?schema=public

# Optional: connection pool size per service instance
DATABASE_POOL_MAX=10


# ----------------------------------------------------------------------------
# Cache — Redis
# ----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# Key namespace prefix (useful when sharing a Redis instance across envs)
REDIS_KEY_PREFIX=omniflow:


# ----------------------------------------------------------------------------
# Authentication — JSON Web Tokens
# ----------------------------------------------------------------------------

# Long random strings — generate with: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token TTLs in seconds (optional — sensible defaults are built in)
# JWT_ACCESS_TTL=900
# JWT_REFRESH_TTL=2592000

# Set to true when behind a reverse proxy (Nginx, AWS ALB, Cloudflare)
TRUST_PROXY=false


# ----------------------------------------------------------------------------
# Stripe — Payments
# ----------------------------------------------------------------------------

# Stripe account secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_

# Stripe publishable key (starts with pk_live_ or pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook endpoint signing secret — from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe API version to pin (keep in sync with @stripe/stripe-js)
STRIPE_API_VERSION=2024-06-20


# ----------------------------------------------------------------------------
# Amazon Web Services
# ----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for user-uploaded assets
AWS_S3_BUCKET=omniflow-assets-dev

# Pre-signed URL TTL in seconds (default: 3600 = 1 hour)
AWS_S3_PRESIGNED_TTL=3600


# ----------------------------------------------------------------------------
# Twilio — SMS & WhatsApp
# ----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=AC
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1

# Optional: Twilio Messaging Service SID for number pooling
# TWILIO_MESSAGING_SERVICE_SID=MG


# ----------------------------------------------------------------------------
# Email — SMTP
# ----------------------------------------------------------------------------

SMTP_HOST=localhost
SMTP_PORT=1025
# Set to true to use TLS (port 465)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Sender identity
FROM_EMAIL=noreply@omniflow.app
FROM_NAME="Omniflow"


# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------

# 'local' for development, 's3' for production
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_URL=http://localhost:3001/uploads


# ----------------------------------------------------------------------------
# MinIO (local S3-compatible — used in docker-compose for development)
# ----------------------------------------------------------------------------

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=omniflow-assets-dev
